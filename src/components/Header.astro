---
const { tabs = [] } = Astro.props;
---

<header class="flex flex-col sm:flex-row w-full items-start sm:items-center justify-between gap-3">
  <div class="flex items-center gap-2 px-4">
      <button class="h-4 w-4 rounded-full bg-adech-sunny-3"></button>
      <button class="h-4 w-4 rounded-full bg-adech-sunny-1"></button>
      <button class="h-4 w-4 rounded-full bg-adech-venomous-1"></button>
  </div>
  <nav class="no-scrollbar relative flex min-w-0 items-center gap-2 overflow-x-auto rounded-lg bg-adech-swamp-1 p-1" aria-label="Portfolio sections" data-tabs-nav>
      <span class="pointer-events-none absolute left-0 top-1 h-[calc(100%-0.5rem)] rounded-md bg-adech-boulevard-3 transition-all duration-300 ease-out" data-tab-indicator />
      {
      tabs.map((tab : any) => (
        <button type="button" data-tab-button={tab.id}
          class="relative z-10 rounded-lg px-4 py-2 text-xs sm:text-sm font-semibold uppercase transition-colors duration-200 text-adech-boulevard-2"
          aria-selected="false"
        >
          {tab.label}
        </button>
      ))
    }
  </nav>
</header>
