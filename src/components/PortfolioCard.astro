---
import Header from "./Header.astro";
import Me from "./Me.astro";
import About from "./About.astro";
import Skills from "./Skills.astro";
import Projects from "./Projects.astro";
import Contact from "./Contact.astro";

const tabs = [
  { id: "about", label: "About" },
  { id: "skills", label: "Skills" },
  { id: "projects", label: "Projects" },
  { id: "contact", label: "Contact" },
];
---

<section class="mx-auto flex min-h-screen w-full max-w-2xl flex-col items-center justify-center gap-2 p-4">
  <Header tabs={tabs} />
  <div class="flex flex-col sm:grid w-full gap-4 rounded-xl bg-adech-swamp-1 p-4 aspect-[1/2] sm:grid-cols-[200px_minmax(0,1fr)] sm:gap-6 sm:aspect-[2/1]">
    <Me />
    <div class="mt-2 min-w-0 overflow-hidden text-adech-boulevard-1">
      <div id="tab-stage" class="h-full">
        <About />
        <Skills />
        <Projects />
        <Contact />
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const VALID_TABS = ["about", "skills", "projects", "contact"];

  const buttons = Array.from(document.querySelectorAll("[data-tab-button]"));
  const panels = Array.from(document.querySelectorAll("[data-tab-panel]"));
  const openContact = document.querySelector("[data-open-contact]");
  const stage = document.getElementById("tab-stage");
  const tabsNav = document.querySelector("[data-tabs-nav]");
  const indicator = document.querySelector("[data-tab-indicator]");

  function getTabFromHash() {
    const hash = window.location.hash.replace("#", "").toLowerCase();
    return VALID_TABS.includes(hash) ? hash : "about";
  }

  function animateStage() {
    if (!stage) return;
    stage.classList.remove("animate-tabEnter");
    void stage.offsetWidth;
    stage.classList.add("animate-tabEnter");
  }

  function moveIndicator(activeButton) {
    if (!tabsNav || !indicator || !activeButton) return;

    const navRect = tabsNav.getBoundingClientRect();
    const btnRect = activeButton.getBoundingClientRect();

    const left = btnRect.left - navRect.left + tabsNav.scrollLeft;
    const width = btnRect.width;

    indicator.style.width = `${width}px`;
    indicator.style.transform = `translateX(${left}px)`;
  }

  let hasMounted = false;

  function activateTab(tabId, updateHash = true) {
    const safeTab = VALID_TABS.includes(tabId) ? tabId : "about";
    let activeButton = null;

    buttons.forEach((button) => {
      const isActive = button.dataset.tabButton === safeTab;

      if (isActive) activeButton = button;

      button.setAttribute("aria-selected", String(isActive));
      button.classList.toggle("text-adech-swamp-3", isActive);
      button.classList.toggle("text-adech-boulevard-2", !isActive);
    });

    panels.forEach((panel) => {
      const isActive = panel.dataset.tabPanel === safeTab;
      panel.classList.toggle("hidden", !isActive);
      panel.classList.toggle("flex", isActive);
    });

    moveIndicator(activeButton);

    if (hasMounted) {
      animateStage();
    } else {
      hasMounted = true;
    }

    if (updateHash && window.location.hash !== `#${safeTab}`) {
      history.replaceState(null, "", `#${safeTab}`);
    }
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      activateTab(button.dataset.tabButton);
    });
  });

  if (openContact) {
    openContact.addEventListener("click", (event) => {
      event.preventDefault();
      activateTab("contact");
    });
  }

  window.addEventListener("hashchange", () => {
    activateTab(getTabFromHash(), false);
  });

  window.addEventListener("resize", () => {
    const current = buttons.find((button) => button.getAttribute("aria-selected") === "true");
    if (current) moveIndicator(current);
  });

  activateTab(getTabFromHash(), false);
</script>

<style is:global>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }

  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  @keyframes tabEnter {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .animate-tabEnter {
    animation: tabEnter 420ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }
</style>
