<section
  class="tab-panel hidden w-full flex-col gap-2 overflow-hidden"
  data-tab-panel="contact"
>
  <h2 class="text-xl font-bold uppercase">Contact</h2>

  <div class="flex flex-col gap-4">
    <form
      id="contact-form"
      class="h-full"
      action="https://formspree.io/f/xwvrvyve"
      method="POST"
    >
      <div class="flex flex-col gap-2 sm:gap-4">
        <div class="grid grid-cols-2 gap-2">
          <label class="flex flex-1 flex-col gap-1">
            <span class="text-sm text-adech-boulevard-2">Name</span>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="rounded-md bg-adech-swamp-2 px-2 py-1 outline-none placeholder:text-adech-boulevard-4"
              placeholder="Your name"
            />
          </label>

          <label class="flex flex-1 flex-col gap-1">
            <span class="text-sm text-adech-boulevard-2">Email</span>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="rounded-md bg-adech-swamp-2 px-2 py-1 outline-none placeholder:text-adech-boulevard-4"
              placeholder="you@email.com"
            />
          </label>
        </div>

        <label class="flex flex-col gap-1">
          <span class="text-sm text-adech-boulevard-2">Message</span>
          <textarea
            id="message"
            name="message"
            rows="2"
            required
            class="resize-none rounded-md bg-adech-swamp-2 px-2 py-1 outline-none placeholder:text-adech-boulevard-4"
            placeholder="Write your message..."
          ></textarea>
        </label>

        <input type="hidden" name="_subject" value="New portfolio message" />

        <button
          id="contact-submit"
          type="submit"
          class="rounded-md bg-adech-boulevard-4 px-2 py-1 text-sm font-semibold text-adech-swamp-3 transition hover:opacity-90 disabled:opacity-60"
        >
          Send message
        </button>

        <p
          id="contact-status"
          class="hidden text-sm text-adech-boulevard-2"
          aria-live="polite"
        ></p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form");
  const submitButton = document.getElementById("contact-submit");
  const status = document.getElementById("contact-status");

  if (form instanceof HTMLFormElement &&
      submitButton instanceof HTMLButtonElement &&
      status instanceof HTMLParagraphElement) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      submitButton.disabled = true;
      submitButton.textContent = "Sending...";
      status.classList.remove("hidden");
      status.textContent = "";

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: {
            Accept: "application/json",
          },
        });

        if (response.ok) {
          form.reset();
          status.textContent = "Message sent successfully.";
        } else {
          status.textContent = "Something went wrong. Please try again.";
        }
      } catch {
        status.textContent = "Connection error. Please try again.";
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = "Send message";
      }
    });
  }
</script>
